<div
  id="curtain"
  class="fixed inset-0 z-200 pointer-events-none"
  data-curtain
  style="display: none;"
>
  <div
    class="absolute inset-y-0 left-0 w-1/2 bg-navy"
    data-curtain-panel="left"
  ></div>
  <div
    class="absolute inset-y-0 right-0 w-1/2 bg-navy"
    data-curtain-panel="right"
  ></div>

  <div
    class="absolute inset-0 flex flex-col items-center justify-center gap-5"
    data-curtain-content
  >
    <div class="flex items-center gap-2">
      <span class="w-3 h-3 rounded-[4px] bg-blue"></span>
      <span class="font-display font-semibold text-2xl text-white">
        NET<span class="text-blue">SH</span>
      </span>
    </div>

    <p class="font-mono text-sm text-white/50 tracking-widest">
      DIGITALIZANDO
    </p>

    <p
      class="font-mono text-4xl md:text-5xl font-semibold text-white tabular-nums"
      data-curtain-counter
    >
      0%
    </p>
  </div>
</div>

<script is:inline>
  (function () {
    try {
      var alreadyShown = sessionStorage.getItem("netsh_curtain_shown");
      var reducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      if (!alreadyShown && !reducedMotion) {
        var curtain = document.getElementById("curtain");
        if (curtain) curtain.style.display = "block";
      }
    } catch (e) {
    }
  })();
</script>