---
const navLinks = [
    { label: "Servicios", href: "#servicios" },
    { label: "Proceso", href: "#proceso" },
    { label: "Templates", href: "#portfolio" },
    { label: "Planes", href: "#planes" },
    { label: "FAQ", href: "#faq" },
];
---

<header
    id="navbar"
    class="fixed top-0 left-0 right-0 z-100 transition-colors duration-300 bg-white/70"
>
    <div
        class="max-w-[1240px] mx-auto px-5 md:px-8 h-[76px] grid grid-cols-[auto_1fr_auto] md:grid-cols-3 items-center gap-4"
    >
        <a
            href="/"
            class="flex items-center gap-2 font-display font-semibold text-lg text-ink justify-self-start"
        >
            <span class="w-2.5 h-2.5 rounded-[3px] bg-blue"></span>
            NET<span class="text-blue">SH</span>
        </a>

        <nav
            class="hidden md:flex items-center justify-center gap-8 text-sm font-medium"
            aria-label="Navegación principal"
        >
            {
                navLinks.map((link) => (
                    <a href={link.href} class="relative py-1 group">
                        {link.label}
                        <span class="absolute left-0 bottom-0 h-[2px] w-0 bg-blue transition-all duration-300 group-hover:w-full" />
                    </a>
                ))
            }
        </nav>

        <div class="flex items-center justify-end gap-3">
            <a
                href="#cta"
                class="hidden md:inline-flex bg-blue text-white text-sm font-semibold px-5 py-2.5 rounded-sm transition-all duration-300 hover:bg-blue-dark hover:-translate-y-0.5 hover:shadow-blue-md"
            >
                Cotizar proyecto
            </a>

            <button
                id="navToggle"
                class="md:hidden flex flex-col gap-[5px] p-2"
                aria-label="Abrir menú"
                aria-expanded="false"
            >
                <span
                    class="w-[22px] h-[2px] bg-ink transition-transform duration-300"
                ></span>
                <span
                    class="w-[22px] h-[2px] bg-ink transition-transform duration-300"
                ></span>
            </button>
        </div>
    </div>

    <nav
        id="navMobile"
        class="hidden flex-col gap-4 px-5 pb-6 pt-4 bg-white border-b border-blue-soft"
        aria-label="Navegación móvil"
    >
        {
            navLinks.map((link) => (
                <a href={link.href} class="font-medium py-1.5">
                    {link.label}
                </a>
            ))
        }
        <a
            href="#cta"
            class="inline-flex justify-center mt-2 bg-blue text-white text-sm font-semibold px-5 py-2.5 rounded-sm"
        >
            Cotizar proyecto
        </a>
    </nav>
</header>

<script>
    const navbar = document.getElementById("navbar");
    const toggle = document.getElementById("navToggle");
    const mobileMenu = document.getElementById("navMobile");

    const scrolledClasses = [
        "bg-white/85",
        "backdrop-blur-md",
        "border-b",
        "border-blue-soft",
        "shadow-blue-sm",
    ];

    const handleScroll = () => {
        if (window.scrollY > 20) {
            navbar?.classList.remove("bg-white/70");
            navbar?.classList.add(...scrolledClasses);
        } else {
            navbar?.classList.add("bg-white/70");
            navbar?.classList.remove(...scrolledClasses);
        }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();

    toggle?.addEventListener("click", () => {
        const isOpen = mobileMenu?.classList.toggle("flex");
        mobileMenu?.classList.toggle("hidden");
        toggle.setAttribute("aria-expanded", String(!!isOpen));

        const spans = toggle.querySelectorAll("span");
        spans[0]?.classList.toggle("rotate-45");
        spans[0]?.classList.toggle("translate-y-[3.5px]");
        spans[1]?.classList.toggle("-rotate-45");
        spans[1]?.classList.toggle("-translate-y-[3.5px]");
    });

    mobileMenu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
            mobileMenu.classList.add("hidden");
            mobileMenu.classList.remove("flex");
            toggle?.setAttribute("aria-expanded", "false");
        });
    });
</script>