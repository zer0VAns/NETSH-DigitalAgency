---
import { projectIncludes } from "../../data/projectIncludes";
---

<section id="incluye" class="section section--soft">
  <div class="grid  container  md:grid-cols-2 gap-16 items-center">
    <div>
      <span class="scan-tag inline-flex items-center text-xs font-medium text-blue mb-6" data-reveal>
        QUÉ RECIBÍS
      </span>

      <h2 class="text-3xl md:text-5xl font-semibold text-ink mb-6" data-reveal data-reveal-delay="0.1">
        ¿Qué incluye cada proyecto?
      </h2>

      <p class="text-base md:text-lg text-slate max-w-md" data-reveal data-reveal-delay="0.2">
        Nada de "página en construcción" ni links rotos. Cada proyecto sale completo,
        funcionando y con vos sabiendo cómo usarlo.
      </p>
    </div>

    <ul class="grid sm:grid-cols-2 gap-x-6 gap-y-4" data-reveal-group>
      {projectIncludes.map((item) => (
        <li class="flex items-start gap-3">
          <span class="mt-0.5 w-5 h-5 rounded-full bg-blue-soft flex items-center justify-center shrink-0">
            <svg
              class="w-3 h-3 text-blue"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="20 6 9 17 4 12" />
            </svg>
          </span>
          <span class="text-sm md:text-base text-ink leading-snug">{item.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>