---
import { process } from "../../data/process";
---

<section id="proceso" class="section container">
<div class="max-w-2xl mx-auto mb-16 text-center">
        <span class="scan-tag inline-flex items-center text-xs font-medium text-blue mb-6" data-reveal>
      CÓMO TRABAJAMOS
    </span>

    <h2 class="text-3xl md:text-5xl font-semibold text-ink" data-reveal data-reveal-delay="0.1">
      Un proceso claro, de punta a punta.
    </h2>
  </div>

<div class="relative max-w-2xl mx-auto" data-reveal-group>
        {process.map((step, index) => (
      <div class="relative flex gap-6 md:gap-10 pb-12 last:pb-0">
        <!-- Columna número + línea vertical -->
        <div class="flex flex-col items-center shrink-0">
          <div class="w-12 h-12 md:w-14 md:h-14 rounded-full bg-blue flex items-center justify-center">
            <span class="font-mono text-xs md:text-sm font-semibold text-white">
              {step.number}
            </span>
          </div>
          {index < process.length - 1 && (
            <div class="w-px flex-1 bg-blue-soft mt-2"></div>
          )}
        </div>

        <!-- Contenido -->
        <div class="pt-1.5 md:pt-2.5">
          <h3 class="text-xl md:text-2xl font-semibold text-ink mb-2">
            {step.title}
          </h3>
          <p class="text-sm md:text-base text-slate max-w-lg leading-relaxed">
            {step.description}
          </p>
        </div>
      </div>
    ))}
  </div>
</section>