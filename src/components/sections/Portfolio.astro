---
import { portfolio } from "../../data/portfolio";
---

<section id="portfolio" class="section container">
  <div class="max-w-2xl mb-14">
    <span class="scan-tag inline-flex items-center text-xs font-medium text-blue mb-6" data-reveal>
      TEMPLATES
    </span>

    <h2 class="text-3xl md:text-5xl font-semibold text-ink" data-reveal data-reveal-delay="0.1">
      Templates de sitios web que podemos personalizar para tu negocio.
    </h2>
  </div>

  <div class="grid sm:grid-cols-2 gap-6" data-reveal-group>
    {portfolio.map((item) => (
      <a
        href={item.demoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group block bg-white rounded-lg border border-blue-soft overflow-hidden transition-all duration-300 hover:border-blue hover:-translate-y-1 hover:shadow-blue-md"
      >
        <!-- Preview mockup tipo browser -->
        <div class="relative aspect-[16/10] bg-blue-soft overflow-hidden">
          <!-- Barra de navegador simulada -->
          <div class="absolute top-0 left-0 right-0 h-8 bg-white/80 backdrop-blur-sm flex items-center gap-1.5 px-3 z-10">
            <span class="w-2 h-2 rounded-full bg-blue-soft border border-blue"></span>
            <span class="w-2 h-2 rounded-full bg-blue-soft border border-blue"></span>
            <span class="w-2 h-2 rounded-full bg-blue-soft border border-blue"></span>
          </div>
          <img
            src={item.image}
            alt={`Vista previa del sitio de ${item.name}`}
            class="w-full h-full object-cover pt-8 transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
        </div>

        <!-- Info -->
        <div class="p-6">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-lg font-semibold text-ink">{item.name}</h3>
            <span class="font-mono text-[0.7rem] text-blue bg-blue-soft px-2 py-1 rounded-sm">
              {item.industry}
            </span>
          </div>
          <p class="text-sm text-slate leading-relaxed">{item.description}</p>
        </div>
      </a>
    ))}
  </div>
</section>