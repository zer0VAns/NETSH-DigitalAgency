---
import { testimonials } from "../../data/testimonials";
---

<section id="testimonios" class="section container">
  <div class="max-w-2xl mb-14">
    <span class="scan-tag inline-flex items-center text-xs font-medium text-blue mb-6" data-reveal>
      CASOS REALES
    </span>

    <h2 class="text-3xl md:text-5xl font-semibold text-ink" data-reveal data-reveal-delay="0.1">
      Lo que dicen los negocios que ya digitalizamos.
    </h2>
  </div>

  <div class="grid md:grid-cols-3 gap-6" data-reveal-group>
    {testimonials.map((t) => (
      <article class="bg-white rounded-lg p-7 shadow-blue-sm border border-blue-soft flex flex-col">
        <svg
          class="w-8 h-8 text-blue-soft mb-4"
          viewBox="0 0 32 32"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M10 8C6.7 8 4 10.7 4 14c0 3 2.1 5.5 5 6.1-.4 1.5-1.6 2.8-3.4 3.6l1 1.9c3.5-1.3 5.9-4.3 5.9-8.4V14c0-3.3-2.7-6-6-6h3.5zm14 0c-3.3 0-6 2.7-6 6 0 3 2.1 5.5 5 6.1-.4 1.5-1.6 2.8-3.4 3.6l1 1.9c3.5-1.3 5.9-4.3 5.9-8.4V14c0-3.3-2.7-6-6-6h3.5z" />
        </svg>

        <p class="text-sm md:text-base text-ink leading-relaxed mb-6 flex-1">
          {t.quote}
        </p>

        <div class="flex items-center gap-3 pt-5 border-t border-blue-soft">
          <div class="w-11 h-11 rounded-full bg-blue flex items-center justify-center shrink-0">
            <span class="font-display font-semibold text-white text-sm">
              {t.initials}
            </span>
          </div>
          <div>
            <p class="text-sm font-semibold text-ink">{t.name}</p>
            <p class="text-xs text-slate">
              {t.business} <span class="text-blue">· {t.industry}</span>
            </p>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>