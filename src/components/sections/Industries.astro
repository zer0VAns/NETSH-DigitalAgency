---
import { industries } from "../../data/industries";
import IndustryIcon from "../ui/IndustryIcon.astro";
---

<section id="industrias" class="section section--soft">
  <div class="container">
    <div class="max-w-2xl mb-14">
      <span class="scan-tag inline-flex items-center text-xs font-medium text-blue mb-6" data-reveal>
        RUBROS
      </span>

      <h2 class="text-3xl md:text-5xl font-semibold text-ink" data-reveal data-reveal-delay="0.1">
        Trabajamos con negocios que atienden gente todos los días.
      </h2>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4" data-reveal-group>
      {industries.map((industry) => (
<div class="bg-white rounded-lg border border-blue-soft shadow-blue-sm p-6 flex flex-col items-center text-center gap-3 transition-all duration-300 hover:border-blue hover:-translate-y-1 hover:shadow-blue-md">          <div class="w-11 h-11 rounded-full bg-blue-soft flex items-center justify-center text-blue">
            <IndustryIcon icon={industry.icon} class="w-5 h-5" />
          </div>
          <p class="text-xs md:text-sm font-medium text-ink leading-snug">
            {industry.name}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>